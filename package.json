{
  "name": "i18n-ai-diff",
  "version": "1.2.0",
  "description": "Multi-master, diff-powered i18n CLI: translate only changed keys with source snapshots, caching, watch mode, and any OpenAI-compatible LLM.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "i18n-ai-diff": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "npm run build:core && npm run build:panel",
    "build:core": "tsc",
    "build:panel": "tsc -p tsconfig.panel.json && vite build --config vite.panel.config.ts",
    "dev": "tsx src/bin/cli.ts",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:package": "npm run build && node scripts/package-smoke.mjs",
    "test:install": "node scripts/install-smoke.mjs",
    "test:consumer": "node scripts/consumer-workspace.mjs verify",
    "test:release": "npm test -- --run && npm run test:package && npm run test:install && npm run test:consumer",
    "consumer:prepare": "node scripts/consumer-workspace.mjs prepare",
    "panel": "npm run build && node dist/bin/cli.js panel",
    "panel:dev": "node scripts/panel-dev.mjs",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "i18n",
    "translation",
    "localization",
    "incremental",
    "diff",
    "cli",
    "llm",
    "ai",
    "openai",
    "gpt",
    "chatgpt",
    "json",
    "watch",
    "cache",
    "typescript",
    "internationalization",
    "ai-translation",
    "translate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JunTong-Wu/i18n-ai-diff.git"
  },
  "homepage": "https://github.com/JunTong-Wu/i18n-ai-diff",
  "bugs": {
    "url": "https://github.com/JunTong-Wu/i18n-ai-diff/issues"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.19.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "cosmiconfig": "^9.0.0",
    "minimatch": "^9.0.3",
    "openai": "^4.28.0",
    "ora": "^8.0.1",
    "p-limit": "^5.0.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-popover": "^1.1.20",
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@visactor/vtable": "1.26.5",
    "@visactor/vtable-editors": "1.26.5",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.56.0",
    "postcss": "^8.4.47",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "sonner": "^2.0.7",
    "tailwindcss": "3.4.17",
    "typescript": "^5.3.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ]
}
